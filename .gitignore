# ── Go ────────────────────────────────────────────────────────────────────────

# Compiled binaries
/webhook
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test artifacts
*.test
*.out
coverage.out
coverage.html

# Go workspace file (local only)
go.work
go.work.sum

# Dependency vendor directory (we use go modules, not vendoring)
vendor/

# ── Build output ──────────────────────────────────────────────────────────────

dist/
bin/
build/

# ── Docker ───────────────────────────────────────────────────────────────────

# Local docker-compose overrides
docker-compose.override.yml

# ── Kubernetes / Helm ─────────────────────────────────────────────────────────

# Helm chart dependencies and lock files (generated)
deploy/helm/**/charts/
deploy/helm/**/Chart.lock

# Rendered manifests (generated by helm template)
rendered/

# kubeconfig — never commit cluster credentials
kubeconfig
*.kubeconfig
.kube/

# ── Terraform / OpenTofu ──────────────────────────────────────────────────────

# Local state — use remote state (S3) in all real environments
deploy/tofu/*.tfstate
deploy/tofu/*.tfstate.backup
deploy/tofu/.terraform/
deploy/tofu/.terraform.lock.hcl

# Variable files often contain secrets — use environment variables or a secrets manager
deploy/tofu/*.tfvars
deploy/tofu/*.tfvars.json

# Crash log files
deploy/tofu/crash.log
deploy/tofu/crash.*.log

# ── Secrets — never commit these ──────────────────────────────────────────────

*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.env
.env
.env.*
secrets.yaml
secrets.yml
*-secret.yaml
*-secret.yml

# ── IDE and editor ────────────────────────────────────────────────────────────

# JetBrains (GoLand)
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Local dev overrides ───────────────────────────────────────────────────────

# Local environment config (use .env.example as the committed template)
.env.local

# Local test credentials (e.g. a real credentials.json for manual testing)
credentials.json
service-account.json
